{
  "name": "obstresla",
  "version": "1.0.0",
  "private": true,
  "description": "SaaS que combina tableros kanban, notas enlazadas y chat en tiempo real",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "migrate:sqlite": "tsx scripts/migrate-sqlite-to-pg.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "marked": "^15.0.7",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
